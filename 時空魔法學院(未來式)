    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700&display=swap');
        body { font-family: 'Noto Sans TC', sans-serif; }
        
        .bg-basic { background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); }
        .bg-advanced { background: linear-gradient(135deg, #2e1065 0%, #000000 100%); }
        
        .theme-tutorial { background: linear-gradient(135deg, #0ea5e9 0%, #3b82f6 100%); }
        .theme-will { background: linear-gradient(135deg, #991b1b 0%, #ef4444 100%); }
        .theme-begoingto { background: linear-gradient(135deg, #166534 0%, #22c55e 100%); }
        .theme-mix { background: linear-gradient(135deg, #6b21a8 0%, #d8b4fe 100%); }
        
        .theme-adv-will { background: linear-gradient(135deg, #7f1d1d 0%, #b91c1c 100%); border-color: #fca5a5; }
        .theme-adv-begoingto { background: linear-gradient(135deg, #14532d 0%, #15803d 100%); border-color: #86efac; }
        .theme-adv-mix { background: linear-gradient(135deg, #581c87 0%, #7e22ce 100%); border-color: #d8b4fe; }

        .animate-pop { animation: pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
        .animate-float { animation: float 3s ease-in-out infinite; }
        .animate-combo { animation: combo-pop 0.5s ease-out; }
        
        @keyframes pop { 0% { transform: scale(0.8); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
        @keyframes shake { 10%, 90% { transform: translate3d(-1px, 0, 0); } 20%, 80% { transform: translate3d(2px, 0, 0); } 30%, 50%, 70% { transform: translate3d(-4px, 0, 0); } 40%, 60% { transform: translate3d(4px, 0, 0); } }
        @keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-10px); } 100% { transform: translateY(0px); } }
        @keyframes combo-pop { 0% { transform: scale(0.5) rotate(-10deg); opacity: 0; } 50% { transform: scale(1.2) rotate(10deg); opacity: 1; } 100% { transform: scale(1) rotate(0deg); opacity: 1; } }
        
        .highlight-time {
            color: #c2410c; 
            background-color: #ffedd5; 
            padding: 0 0.25rem;
            border-radius: 0.25rem;
            font-weight: 800;
            border-bottom: 2px solid #f97316;
            display: inline-block;
        }
        
        .highlight-time-adv {
            color: #fcd34d;
            font-weight: bold;
            text-decoration: underline;
            text-underline-offset: 4px;
        }
    </style>
</head>
