                                            {topic === 'will' && <Star size={48} className={`mb-4 ${isMastered ? 'text-yellow-300 animate-pulse' : 'text-white'}`} />}
                                            {topic === 'begoingto' && <RefreshCcw size={48} className={`mb-4 ${isMastered ? 'text-yellow-300 animate-pulse' : 'text-white'}`} />}
                                            {topic === 'mix' && <Award size={48} className={`mb-4 ${isMastered ? 'text-yellow-300 animate-pulse' : 'text-white'}`} />}
                                            <h2 className="text-2xl font-bold mb-2 uppercase">{topic === 'will' ? 'Will Zone' : topic === 'begoingto' ? 'Going To Zone' : 'Mix Challenge'}</h2>
                                            <p className="opacity-80 font-mono">
                                                {isMastered ? <span className="font-bold text-yellow-300">MASTERED!</span> : `Level: ${level}/3`}
                                            </p>
                                            {!isTutorialDone && <div className="absolute inset-0 bg-black/60 flex items-center justify-center"><Lock size={48} className="text-white/50" /></div>}
                                        </button>
                                    );
                                })}
                            </div>
                        </div>
                    </div>
                );
            };

            const renderGame = () => {
                if (!currentQ) return <div>Loading...</div>;
                
                const isBasic = mode === 'basic';
                const themeClass = isBasic ? (selectedTopic === 'tutorial' ? 'theme-tutorial' : selectedTopic === 'will' ? 'theme-will' : selectedTopic === 'begoingto' ? 'theme-begoingto' : 'theme-mix') : 'bg-gray-800'; 

                return (
                    <div className={`flex flex-col min-h-screen ${isBasic ? 'bg-slate-50' : 'bg-gray-900 text-gray-200'}`}>
                        <div className={`p-4 shadow-md flex justify-between items-center text-white ${themeClass}`}>
                            <button onClick={() => setGameState(selectedTopic === 'tutorial' ? 'home' : 'level-select')} className="hover:bg-white/20 p-2 rounded-lg flex items-center gap-1 font-bold"><ArrowLeft size={20} /> Quit</button>
                            <div className="flex flex-col items-center">
                                <div className="font-bold text-xl">{selectedTopic === 'tutorial' ? "Tutorial" : `${mode === 'advanced' ? 'Adv.' : ''} Level ${selectedLevel}`} - Q{currentQIndex + 1}</div>
                                {streak > 1 && <div className="text-yellow-300 font-bold text-sm animate-pulse">🔥 {streak} COMBO!</div>}
                            </div>
                            <div className="font-mono bg-black/20 px-4 py-1 rounded-full font-bold flex items-center gap-2"><Award size={16} className="text-yellow-400"/> {currentLevelScore}</div>
                        </div>

                        <div className="flex-1 flex flex-col items-center justify-center p-4 py-8 max-w-4xl mx-auto w-full">
                            <div className={`${isBasic ? 'bg-white text-gray-800' : 'bg-gray-800 text-white border-gray-700'} rounded-3xl p-8 shadow-xl w-full mb-8 min-h-[300px] flex flex-col items-center justify-center relative border-4 border-transparent`}>
                                <h2 className="text-3xl font-bold mb-6 text-center leading-relaxed">{renderHighlightedText(currentQ.question)}</h2>
                                <div className={`transition-all duration-500 ease-in-out overflow-hidden ${showHint ? 'max-h-20 opacity-100 mb-6' : 'max-h-0 opacity-0 mb-0'}`}>
                                    <div className="text-base text-gray-600 bg-yellow-50 px-4 py-2 rounded-full border border-yellow-200 flex items-center gap-2 shadow-sm"><Lightbulb className="text-yellow-500" size={20} /><span className="font-bold">Hint: {currentQ.hint}</span></div>
                                </div>

                                {/* Level 1 & Tutorial: Choice */}
                                {(selectedTopic === 'tutorial' || selectedLevel === 1) && (
                                    <div className="w-full max-w-2xl">
                                        <div className={`text-2xl text-center mb-8 font-mono p-6 rounded-xl border-2 border-dashed font-bold ${isBasic ? 'bg-gray-50 border-gray-200 text-blue-900' : 'bg-gray-900 border-gray-600 text-green-300'}`}>{renderHighlightedText(currentQ.sentence)}</div>
                                        <div className="grid grid-cols-3 gap-4">
                                            {currentQ.options.map((opt, idx) => (
                                                <button key={idx} disabled={feedback !== null} onClick={() => handleAnswer(opt.correct)} className={`${isBasic ? 'bg-slate-600 hover:bg-slate-700' : 'bg-indigo-600 hover:bg-indigo-700'} text-white text-xl font-bold py-6 rounded-xl hover:scale-105 transform transition shadow-lg disabled:opacity-50 disabled:transform-none`}>{opt.text}</button>
                                            ))}
                                        </div>
                                    </div>
                                )}

                                {/* Level 2: Scramble */}
                                {selectedLevel === 2 && (
                                    <div className="w-full">
                                        <div className={`${isBasic ? 'bg-gray-100' : 'bg-gray-700'} min-h-[100px] rounded-xl p-6 mb-8 flex flex-wrap gap-3 items-center justify-center border-2 border-dashed ${isBasic ? 'border-gray-300' : 'border-gray-500'}`}>
                                            {scrambleAnswer.map((item, idx) => <button key={idx} onClick={() => {
                                                const newAns = [...scrambleAnswer]; newAns.splice(idx, 1); setScrambleAnswer(newAns);
                                                setScramblePool([...scramblePool, item]);
                                            }} className={`${item.color} text-white px-5 py-3 rounded-lg font-bold text-xl shadow-md animate-pop`}>{renderHighlightedText(item.text)}</button>)}
                                        </div>
                                        <div className="flex flex-wrap gap-3 justify-center mb-8">
                                            {scramblePool.map((item, idx) => <button key={idx} onClick={() => {
                                                const newPool = [...scramblePool]; newPool.splice(idx, 1); setScramblePool(newPool);
                                                setScrambleAnswer([...scrambleAnswer, item]);
                                            }} className={`${item.color} text-white px-5 py-3 rounded-lg font-bold text-xl shadow-lg hover:scale-105 transition`}>{renderHighlightedText(item.text)}</button>)}
                                        </div>
                                        <button onClick={() => {
                                            const ans = scrambleAnswer.map(p => p.text).join(" "); const cor = currentQ.parts.map(p => p.text).join(" ");
                                            handleAnswer(ans === cor);
                                        }} disabled={feedback !== null || scramblePool.length > 0} className={`w-full py-4 rounded-xl font-bold text-2xl text-white transition shadow-lg ${scramblePool.length > 0 ? 'bg-gray-400' : (isBasic ? 'bg-blue-600 hover:bg-blue-700' : 'bg-indigo-600 hover:bg-indigo-700')}`}>Check</button>
                                    </div>
                                )}

                                {/* Level 3: Fill (Basic has choices, Advanced is Typing) */}
                                {selectedLevel === 3 && (
                                    <div className="w-full text-center max-w-2xl">
                                        <div className="text-3xl mb-10 flex flex-wrap justify-center items-center gap-3 font-mono leading-loose">
                                            {currentQ.sentence.map((part, idx) => (
                                                part === "input" ? (
                                                    <div key={idx} className={`border-b-4 ${inputValue ? 'border-green-500 text-green-500' : (isBasic ? 'border-blue-500 text-blue-900' : 'border-indigo-500 text-indigo-200')} ${isBasic ? 'bg-blue-50' : 'bg-gray-900'} w-40 text-center font-bold px-2 py-1 rounded-t min-h-[3rem] flex items-center justify-center`}>{inputValue || "?"}</div>
                                                ) : <span key={idx}>{renderHighlightedText(part)}</span>
                                            ))}
                                        </div>
                                        
                                        {/* Basic Mode Word Bank */}
                                        {isBasic && currentQ.choices && (
                                            <div className="bg-slate-50 p-6 rounded-2xl border border-slate-200">
                                                <div className="flex gap-4 justify-center">
                                                    {currentQ.choices.map((word, idx) => (
                                                        <button key={idx} onClick={() => {
                                                            if(feedback) return;
                                                            if(word.toLowerCase() === currentQ.answer.toLowerCase()) { setInputValue(word); handleAnswer(true); } else { handleAnswer(false); }
                                                        }} disabled={feedback !== null} className="bg-white border-2 border-slate-300 hover:border-blue-500 text-slate-700 text-xl font-bold px-6 py-3 rounded-xl transition shadow-sm hover:shadow-md">{word}</button>
                                                    ))}
                                                </div>
                                            </div>
                                        )}

                                        {/* Advanced Mode Typing */}
                                        {!isBasic && (
                                            <div className="flex flex-col gap-4">
                                                <input 
                                                    type="text" 
                                                    autoFocus
                                                    className="bg-gray-700 border-2 border-gray-600 text-white text-center text-2xl p-4 rounded-xl focus:border-indigo-500 outline-none"
                                                    placeholder="Type answer here..." 
                                                    value={inputValue}
                                                    onChange={(e) => setInputValue(e.target.value)}
                                                    onKeyDown={(e) => {
                                                        if(e.key === 'Enter' && inputValue && !feedback) {
                                                            if(inputValue.toLowerCase().trim() === currentQ.answer.toLowerCase()) { handleAnswer(true); } else { handleAnswer(false); }
                                                        }
                                                    }}
                                                    disabled={feedback !== null}
                                                />
                                                <div className="text-gray-400 text-sm">按 Enter 送出</div>
                                            </div>
                                        )}
                                    </div>
                                )}

                                {/* Feedback Overlay */}
                                {feedback && (
                                    <div className="absolute inset-0 bg-white/95 rounded-3xl flex flex-col items-center justify-center animate-pop z-10 backdrop-blur-sm text-gray-800">
                                        {feedback.type === 'correct' ? 
                                            <div className="text-center">
                                                <CheckCircle size={80} className="text-green-500 mb-4 mx-auto" />
                                                {feedback.combo > 1 && <div className="text-3xl font-black text-yellow-500 mb-2 animate-combo italic">COMBO x{feedback.combo}!</div>}
                                                <div className="text-xl font-bold text-green-600">{feedback.pointsAdded > 0 ? `+${feedback.pointsAdded} Points` : 'Retry (0 Pts)'}</div>
                                            </div> 
                                            : <div className="animate-shake flex flex-col items-center"><XCircle size={80} className="text-red-500 mb-4" /></div>
                                        }
                                        <h3 className={`text-3xl font-bold mb-2 ${feedback.type === 'correct' ? 'text-green-700' : 'text-red-700'}`}>{feedback.msg}</h3>
                                        {feedback.type === 'wrong' && <p className="text-gray-500 mt-2">Hint unlocking...</p>}
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                );
            };

            const renderResult = () => {
                const isGrandMaster = checkAllCompleted();
                const isTopicMastered = selectedLevel === 3 && currentProgress[selectedTopic] >= 4;
                
                if (isGrandMaster) {
                    return (
                        <div className="flex flex-col items-center justify-center min-h-screen bg-black text-white p-6 relative overflow-hidden py-10">
                            <div className="text-center animate-pop z-10">
                                <div className="inline-block p-4 rounded-full bg-yellow-400 mb-6 shadow-[0_0_50px_rgba(250,204,21,0.5)] animate-float"><Award size={120} className="text-black" /></div>
                                <h2 className="text-5xl font-bold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-yellow-300 to-amber-500">{mode === 'basic' ? "恭喜畢業！" : "時空領主誕生！"}</h2>
                                <p className="text-2xl mb-8 text-gray-300">{mode === 'basic' ? "你已通過基礎修練！" : "你已征服所有時空難題！"}</p>
                                <div className="bg-white/10 backdrop-blur-md p-8 rounded-2xl border border-white/20 mb-8"><p className="text-gray-400 mb-2">Total Score</p><p className="text-6xl font-mono font-bold text-yellow-400">{currentScore}</p></div>
                                <button onClick={() => setGameState('mode-select')} className="bg-blue-600 text-white px-10 py-4 rounded-full font-bold text-xl hover:bg-blue-700 shadow-xl">Back to Academy</button>
                            </div>
                        </div>
                    );
                }

                return (
                    <div className="flex flex-col items-center justify-center min-h-screen bg-white text-gray-800 p-6 py-10">
                        <div className="text-center animate-pop">
                            <Award size={100} className="text-yellow-500 mx-auto mb-4" />
                            <h2 className="text-4xl font-bold mb-2">{isTopicMastered ? "領域制霸！" : "關卡完成！"}</h2>
                            <p className="text-xl text-gray-500 mb-6">Score: <span className="text-blue-600 font-bold text-3xl ml-2">{currentLevelScore}</span></p>
                            <div className="flex gap-4 justify-center">
                                <button onClick={() => startGame(selectedTopic, selectedLevel)} className="bg-gray-200 px-8 py-3 rounded-full font-bold hover:bg-gray-300">Replay</button>
                                <button onClick={() => setGameState('level-select')} className="bg-blue-600 text-white px-8 py-3 rounded-full font-bold hover:bg-blue-700 shadow-lg">Continue</button>
                            </div>
                        </div>
                    </div>
                );
            };

            const renderLevelSelect = () => {
                const currentProgressVal = currentProgress[selectedTopic];
                const LevelButton = ({ lvl, title, desc, numberColor }) => {
                    const isLocked = lvl > currentProgressVal && currentProgressVal < 4;
                    return (
                        <button onClick={() => startGame(lvl)} disabled={isLocked} className={`relative p-6 rounded-xl flex items-center transition border-2 ${isLocked ? 'bg-black/20 border-white/10 opacity-60 cursor-not-allowed' : 'bg-white/10 hover:bg-white/20 backdrop-blur-sm border-white/30 cursor-pointer'}`}>
                            {isLocked ? <div className="w-12 h-12 rounded-full bg-gray-600 flex items-center justify-center mr-4"><Lock className="text-gray-400" /></div> : <div className={`${numberColor} text-white w-12 h-12 rounded-full flex items-center justify-center font-bold text-xl mr-4 shadow-lg`}>{lvl}</div>}
                            <div className="text-left flex-1">
                                <h3 className="font-bold text-xl">{title}</h3>
                                <p className="text-sm opacity-70">{desc}</p>
                            </div>
                        </button>
                    );
                };

                return (
                    <div className={`flex flex-col items-center justify-center min-h-screen text-white p-6 py-10 ${mode === 'basic' ? 'bg-basic' : 'bg-advanced'}`}>
                        <button onClick={() => setGameState('home')} className="absolute top-6 left-6 text-white/80 hover:text-white flex items-center gap-2 text-lg font-bold bg-black/20 px-4 py-2 rounded-full z-10"><ArrowLeft /> Back</button>
                        <div className="mb-8 text-center animate-pop mt-10 md:mt-0"><h2 className="text-4xl font-bold mb-2">{mode === 'basic' ? "選擇等級" : "Select Level"}</h2></div>
                        <div className="grid gap-4 w-full max-w-md">
                            {[1, 2, 3].map(lvl => {
                                const isLocked = lvl > currentProgressVal && currentProgressVal < 4;
                                return (
                                    <button key={lvl} onClick={() => { if(!isLocked) startGame(selectedTopic, lvl); }} disabled={isLocked} className={`relative p-6 rounded-xl flex items-center transition border-2 ${isLocked ? 'bg-black/20 border-white/10 opacity-60 cursor-not-allowed' : 'bg-white/10 hover:bg-white/20 backdrop-blur-sm border-white/30 cursor-pointer'}`}>
                                        {isLocked ? <div className="w-12 h-12 rounded-full bg-gray-600 flex items-center justify-center mr-4"><Lock className="text-gray-400" /></div> : <div className="bg-yellow-500 text-white w-12 h-12 rounded-full flex items-center justify-center font-bold text-xl mr-4 shadow-lg">{lvl}</div>}
                                        <div className="text-left flex-1"><h3 className="font-bold text-xl">Level {lvl}</h3><p className="text-sm opacity-70">{mode === 'basic' ? (lvl===1?"選擇題":lvl===2?"重組":"填空") : (lvl===1?"Choice":lvl===2?"Scramble":"Typing")}</p></div>
                                    </button>
                                );
                            })}
                        </div>
                    </div>
                );
            };

            // Main Router
            return (
                <div className="min-h-screen">
                    {gameState === 'mode-select' && renderModeSelection()}
                    {gameState === 'home' && renderHome()}
                    {gameState === 'level-select' && renderLevelSelect()}
                    {gameState === 'playing' && renderGame()}
                    {gameState === 'result' && renderResult()}
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
