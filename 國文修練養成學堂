                                  <button disabled className="w-full py-1.5 md:py-2 rounded-xl bg-slate-200 text-slate-400 font-bold text-xs">尚未解鎖</button>
                                )}
                              </div>
                            )}
                          </div>
                        );
                      })}
                    </div>
                    <button onClick={() => setShowCollection(false)} className="mt-2 shrink-0 bg-slate-100 text-slate-600 font-bold py-3 rounded-xl hover:bg-slate-200 transition-all">關閉圖鑑</button>
                  </div>
                </div>
              )}
            </div>
          );
        }

        function QuizRoom({ onResult, currentCookies, streak, onResetStreak, doubleTimeLeft, activeEquipment, protectionCooldown, triggerProtection }) {
          const [selectedBook, setSelectedBook] = useState('1-L7');
          const [selectedStage, setSelectedStage] = useState('stage1');
          const [currentQ, setCurrentQ] = useState(null);
          const [options, setOptions] = useState([]);
          const [isProcessing, setIsProcessing] = useState(false);
          const [feedback, setFeedback] = useState(null); 
          const [lockTimer, setLockTimer] = useState(0); 
          const [lastEarned, setLastEarned] = useState(0);

          const [questionQueue, setQuestionQueue] = useState([]);

          const [examState, setExamState] = useState({
            active: false,
            finished: false,
            questions: [],
            currentIndex: 0,
            correctCount: 0
          });

          const isExamBook = BOOKS.find(b => b.id === selectedBook)?.type === 'exam';
          
          const targetStreak = useMemo(() => {
            if (isExamBook) return 10; 
            const stageConf = STAGES.find(s => s.id === selectedStage);
            return stageConf ? stageConf.streakReq : 10;
          }, [selectedStage, isExamBook]);

          const getPool = (bookId, stageId) => {
            return QUESTION_BANK[bookId]?.[stageId] || [];
          };

          const getNextQuestionFromQueue = () => {
            let queue = [...questionQueue];
            if (queue.length === 0) {
              const pool = getPool(selectedBook, selectedStage);
              if (pool.length === 0) return null;
              queue = shuffleArray([...pool]);
            }
            const nextQ = queue.pop();
            setQuestionQueue(queue);
            return nextQ;
          };

          const loadNewQuestion = () => {
            const q = getNextQuestionFromQueue();
            if (!q) {
              setCurrentQ(null);
              setIsProcessing(false);
              return;
            }
            setCurrentQ(q);
            setOptions(shuffleArray([...q.options]));
            setFeedback(null);
            setIsProcessing(false);
            setLockTimer(0);
          };

          useEffect(() => {
            if (!isExamBook) {
              const pool = getPool(selectedBook, selectedStage);
              const newQueue = shuffleArray([...pool]);
              const nextQ = newQueue.pop() || null;
              setQuestionQueue(newQueue);
              
              setCurrentQ(nextQ);
              if (nextQ) setOptions(shuffleArray([...nextQ.options]));
              setFeedback(null);
              setIsProcessing(false);
              setLockTimer(0);
            } else {
              setExamState(prev => ({...prev, active: false, finished: false}));
            }
          }, [selectedBook, selectedStage]);

          useEffect(() => {
            return () => window.speechSynthesis && window.speechSynthesis.cancel();
          }, []);

          const startExam = () => {
            const bookConf = BOOKS.find(b => b.id === selectedBook);
            let allQs = [];
            bookConf.pools.forEach(bId => {
               if (QUESTION_BANK[bId]) {
                  allQs = allQs.concat(QUESTION_BANK[bId].stage1 || []);
                  allQs = allQs.concat(QUESTION_BANK[bId].stage2 || []);
                  allQs = allQs.concat(QUESTION_BANK[bId].stage3 || []);
               }
            });
            
            allQs = shuffleArray([...allQs]);
            const selected20 = allQs.slice(0, 20);

            if (selected20.length === 0) {
              alert('此大試煉的題庫尚未建立，無法開始喔！');
              return;
            }

            setExamState({
              active: true,
              finished: false,
              questions: selected20,
              currentIndex: 0,
              correctCount: 0
            });

            const q = selected20[0];
            setCurrentQ(q);
            setOptions(shuffleArray([...q.options]));
          };

          const nextExamQ = () => {
            setFeedback(null);
            setIsProcessing(false);
            setLockTimer(0);
            window.speechSynthesis && window.speechSynthesis.cancel();

            setExamState(prev => {
               const nextIdx = prev.currentIndex + 1;
               if(nextIdx >= prev.questions.length) {
                   return { ...prev, finished: true, active: false };
               }
               const nextQ = prev.questions[nextIdx];
               setCurrentQ(nextQ);
               setOptions(shuffleArray([...nextQ.options]));
               return { ...prev, currentIndex: nextIdx };
            });
          };

          const speakExplanation = (answer, explanation) => {
            if (!window.speechSynthesis) return;
            window.speechSynthesis.cancel();
            const textToRead = `正確答案是：${answer}。${explanation ? `解析：${explanation}` : ''}`;
            const utterance = new SpeechSynthesisUtterance(textToRead);
            utterance.lang = 'zh-TW';
            utterance.rate = 1.0;
            window.speechSynthesis.speak(utterance);
          };

          const handleAnswer = (opt) => {
            if (isProcessing) return;
            setIsProcessing(true);
            
            let isCorrect = false;
            let reward = 0;
            let qData = currentQ;

            if (isExamBook && examState.active) {
              qData = examState.questions[examState.currentIndex];
              isCorrect = opt === qData.a;
              reward = 5;
            } else {
              isCorrect = opt === currentQ.a;
              reward = STAGES.find(s => s.id === selectedStage).reward;
            }

            if (isCorrect) {
              playSound('correct');
              setFeedback('correct');

              let eqBonus = activeEquipment === 6 ? 1 : 0;
              if (activeEquipment === 14 && selectedStage === 'stage3') eqBonus += 3;
              let finalAmt = doubleTimeLeft > 0 ? (reward + eqBonus) * 2 : (reward + eqBonus);
              setLastEarned(finalAmt);

              onResult(true, qData, opt, reward, targetStreak, false, false, selectedBook, selectedStage);
              
              if (isExamBook) {
                setExamState(prev => ({...prev, correctCount: prev.correctCount + 1}));
                setTimeout(() => nextExamQ(), 800);
              } else {
                setTimeout(() => loadNewQuestion(), 800);
              }
            } else {
              let usedProtection = false;
              if (activeEquipment?.id === 3 && protectionCooldown === 0) {
                  usedProtection = true;
                  triggerProtection();
              }

              playSound('wrong');
              setFeedback(usedProtection ? 'protected' : 'wrong');
              onResult(false, qData, opt, 0, targetStreak, false, usedProtection, selectedBook, selectedStage);
              
              speakExplanation(qData.a, qData.exp);
              setLockTimer(activeEquipment?.id === 20 ? 2 : 5);
              
              const timerInterval = setInterval(() => {
                setLockTimer(prev => {
                  if (prev <= 1) {
                    clearInterval(timerInterval);
                    return 0;
                  }
                  return prev - 1;
                });
              }, 1000);
            }
          };

          const handleRetry = (opt) => {
              if (opt !== currentQ.a) {
                  playSound('wrong');
                  speakExplanation(currentQ.a, currentQ.exp);
                  setLockTimer(activeEquipment?.id === 20 ? 2 : 5);
                  const timerInterval = setInterval(() => {
                    setLockTimer(prev => {
                      if (prev <= 1) {
                        clearInterval(timerInterval);
                        return 0;
                      }
                      return prev - 1;
                    });
                  }, 1000);
              } else {
                  playSound('correct');
                  let reward = isExamBook ? 5 : STAGES.find(s => s.id === selectedStage).reward;
                  let baseR = Math.ceil(reward / 2);
                  let eqBonusRetry = activeEquipment === 6 ? 1 : 0;
                  if (activeEquipment === 14 && selectedStage === 'stage3') eqBonusRetry += 3;
                  if (activeEquipment === 10) eqBonusRetry += 2;
                  let finalAmtRetry = doubleTimeLeft > 0 ? (baseR + eqBonusRetry) * 2 : (baseR + eqBonusRetry);
                  setLastEarned(finalAmtRetry);

                  onResult(true, currentQ, opt, reward, targetStreak, true, false, selectedBook, selectedStage);
                  setFeedback('correct');
                  if (isExamBook) {
                    setTimeout(() => nextExamQ(), 800);
                  } else {
                    setTimeout(() => loadNewQuestion(), 800);
                  }
              }
          };

          const handleRetryAfterWrong = () => {
            window.speechSynthesis && window.speechSynthesis.cancel();
            setFeedback('retry_mode');
            setLockTimer(0);
          };

          const isNormalEmpty = !isExamBook && getPool(selectedBook, selectedStage).length === 0;
          const needsSingleColumn = currentQ?.options?.some(opt => opt.length > 15) || selectedStage === 'stage3';
          
          const getWrongAnswerTextSize = (ans) => {
            if (!ans) return 'text-4xl';
            const len = ans.length;
            if (len > 25) return 'text-xl md:text-2xl';
            if (len > 12) return 'text-2xl md:text-4xl';
            return 'text-5xl md:text-7xl'; 
          };

          const formatTime = (secs) => {
              const m = Math.floor(secs / 60);
              const s = secs % 60;
              return `${m}:${s < 10 ? '0' : ''}${s}`;
          };

          return (
            <div className="h-full flex flex-col relative w-full overflow-hidden">
              <div className="flex flex-col md:flex-row gap-2 mb-2 md:mb-3 shrink-0 justify-between items-center px-1">
                <div className="flex-1 bg-emerald-50 rounded-xl p-1 flex items-center border border-emerald-200 shadow-sm relative w-full md:w-auto">
                  <Book className="text-emerald-600 absolute left-3" size={20} />
                  <select 
                    value={selectedBook} 
                    onChange={e => { 
                      setSelectedBook(e.target.value); 
                      setIsProcessing(false); 
                      setFeedback(null); 
                      onResetStreak(); 
                    }}
                    className="w-full bg-transparent font-black text-slate-700 pl-10 pr-4 py-2 outline-none appearance-none cursor-pointer text-sm md:text-base"
                  >
                    <optgroup label="國一武功祕笈">
                      {BOOKS.filter(b => b.id.startsWith('1-')).map(b => (
                        <option key={b.id} value={b.id}>{b.name}</option>
                      ))}
                    </optgroup>
                    <optgroup label="國二武功祕笈">
                      {BOOKS.filter(b => b.id.startsWith('2-')).map(b => (
                        <option key={b.id} value={b.id}>{b.name}</option>
                      ))}
                    </optgroup>
                    <optgroup label="大試煉">
                      {BOOKS.filter(b => b.id.startsWith('exam-')).map(b => (
                        <option key={b.id} value={b.id}>{b.name}</option>
                      ))}
                    </optgroup>
                  </select>
                  <div className="pointer-events-none absolute inset-y-0 right-3 flex items-center px-2 text-emerald-600">
                    <svg className="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                
                <div className="flex gap-2 w-full md:w-auto overflow-x-auto">
                    {activeEquipment?.id === 3 && protectionCooldown > 0 && (
                        <div className="bg-slate-100 border border-slate-200 text-slate-500 px-3 py-2 rounded-xl font-bold text-xs flex items-center gap-1 shadow-sm shrink-0">
                           <Lock size={14}/> 金牌冷卻: {formatTime(protectionCooldown)}
                        </div>
                    )}
                    <div className="bg-orange-100 border border-orange-200 text-orange-600 px-4 py-2 rounded-xl font-black text-sm flex items-center gap-2 shadow-sm shrink-0 w-full md:w-auto justify-center">
                       <Flame className={streak > 0 ? "animate-pulse" : ""} size={18} /> 連續答對: {streak}/{targetStreak}
                    </div>
                </div>
              </div>

              {!isExamBook && (
                <div className="flex justify-between gap-1.5 md:gap-3 mb-2 md:mb-4 shrink-0 w-full px-1">
                  {STAGES.map(s => {
                    const parts = s.name.split('：');
                    return (
                      <button 
                        key={s.id} 
                        onClick={() => {
                          if (!isProcessing && selectedStage !== s.id) {
                            setSelectedStage(s.id);
                            onResetStreak();
                          }
                        }}
                        className={`flex-1 flex flex-col items-center justify-center py-2 px-1 md:p-3 rounded-xl md:rounded-2xl font-bold transition-all border-2 ${
                          selectedStage === s.id 
                            ? 'bg-emerald-50 text-emerald-800 border-emerald-400 shadow-sm' 
                            : 'bg-white text-slate-500 border-slate-100 hover:bg-slate-50 hover:border-slate-300'
                        }`}
                      >
                        <span className="text-sm md:text-lg whitespace-nowrap">{parts[0]}</span>
                        {parts[1] && (
                          <span className={`text-[10px] md:text-xs font-medium mt-0.5 whitespace-nowrap hidden sm:block ${selectedStage === s.id ? 'text-emerald-600' : 'text-slate-400'}`}>
                            {parts[1]}
                          </span>
                        )}
                      </button>
                    );
                  })}
                </div>
              )}

              {isExamBook && !examState.active && !examState.finished && (
                <div className="flex-1 flex flex-col items-center justify-center p-6 text-center bg-white rounded-3xl border-2 border-emerald-50 overflow-y-auto">
                  <Trophy size={80} className="text-amber-500 mb-4 animate-bounce shrink-0" />
                  <h2 className="text-3xl font-black text-slate-800 mb-4">全能武功大試煉</h2>
                  <p className="text-slate-600 font-bold mb-8 leading-relaxed max-w-sm">
                    將隨機抽出 20 題考驗你的真實功力！每答對一題可獲得 5 餅乾。
                  </p>
                  <button onClick={startExam} className="bg-amber-500 text-white px-8 py-4 rounded-2xl font-black text-2xl shadow-lg hover:bg-amber-600 active:scale-95 transition-all">
                    開始挑戰
                  </button>
                </div>
              )}

              {isExamBook && examState.finished && (
                <div className="flex-1 flex flex-col items-center justify-center p-6 text-center bg-white rounded-3xl border-2 border-emerald-50 overflow-y-auto">
                  <div className="text-8xl mb-4 shrink-0">🎉</div>
                  <h2 className="text-3xl font-black text-slate-800 mb-2">試煉完成！</h2>
                  <p className="text-2xl font-bold text-slate-600 mb-6">
                    你成功答對了 <span className="text-green-600 text-4xl mx-1">{examState.correctCount}</span> / 20 題
                  </p>
                  <button onClick={startExam} className="bg-emerald-500 text-white px-8 py-4 rounded-2xl font-black text-xl shadow-lg hover:bg-emerald-600 active:scale-95 transition-all">
                    再次挑戰
                  </button>
                </div>
              )}

              {isNormalEmpty && (
                <div className="flex-1 flex flex-col items-center justify-center p-6 text-center bg-white rounded-3xl border-2 border-emerald-50 text-slate-400 overflow-y-auto">
                   <Book size={60} className="mb-4 opacity-50 shrink-0" />
                   <h2 className="text-xl md:text-2xl font-bold">此武功祕笈正在閉關撰寫中...</h2>
                   <p className="mt-2 text-sm">請選擇有題目的秘笈進行修練喔！</p>
                </div>
              )}

              {currentQ && (!isExamBook || (isExamBook && examState.active)) && !isNormalEmpty && (
                <div className={`flex-1 bg-white rounded-3xl shadow-sm border-2 overflow-y-auto flex flex-col relative mx-1 md:mx-0 transition-all duration-300 ${doubleTimeLeft > 0 ? 'border-yellow-400 shadow-[0_0_15px_rgba(250,204,21,0.4)]' : 'border-emerald-50'}`}>
                  
                  {doubleTimeLeft > 0 && (
                    <div className="bg-gradient-to-r from-yellow-400 to-amber-500 text-white text-center py-1.5 font-black tracking-widest text-sm shadow-md shrink-0 flex justify-center items-center gap-2">
                        <Sparkles size={16} className="animate-pulse" />
                        財神降臨！雙倍餅乾倒數：{formatTime(doubleTimeLeft)}
                        <Sparkles size={16} className="animate-pulse" />
                    </div>
                  )}

                  {isExamBook && (
                    <div className="bg-slate-100 text-center py-2 font-black text-slate-500 text-sm tracking-widest relative shrink-0">
                      <div className="absolute top-0 left-0 h-full bg-amber-200/50 transition-all duration-300" style={{ width: `${((examState.currentIndex) / 20) * 100}%` }}></div>
                      <span className="relative z-10">試煉進度：{examState.currentIndex + 1} / 20</span>
                    </div>
                  )}

                  {(feedback === 'wrong' || feedback === 'protected') && (
                    <div className={`absolute inset-0 z-50 ${feedback === 'protected' ? 'bg-orange-500/95' : 'bg-red-500/95'} flex flex-col items-center justify-center text-white p-4 md:p-8 animate-in fade-in zoom-in duration-200 text-center overflow-y-auto`}>
                      <div className={`flex items-center justify-center gap-2 mb-2 ${feedback === 'protected' ? 'text-orange-100' : 'text-red-200'} shrink-0`}>
                        {feedback === 'protected' ? <Lock size={40} className="animate-pulse" /> : <XCircle size={40} className="animate-pulse" />}
                        <Volume2 size={24} className="opacity-70" />
                      </div>
                      
                      {feedback === 'protected' && (
                          <div className="bg-orange-800 text-white px-4 py-1 rounded-full font-bold text-sm mb-4">免死金牌生效！連擊不中斷</div>
                      )}

                      <h2 className="text-xl md:text-3xl font-bold mb-2 shrink-0">正確答案是：</h2>
                      
                      <div className={`${getWrongAnswerTextSize(currentQ.a)} font-black drop-shadow-xl my-3 tracking-wide break-words whitespace-pre-wrap w-full max-w-3xl leading-snug shrink-0`}>
                        {currentQ.a}
                      </div>

                      {currentQ.exp && (
                        <div className="bg-white/20 p-4 md:p-6 rounded-2xl max-w-2xl w-full text-left my-4 shadow-inner shrink-0">
                          <span className={`${feedback==='protected' ? 'bg-orange-800 text-orange-100' : 'bg-red-800 text-red-100'} text-sm font-bold px-2 py-1 rounded mb-2 inline-block`}>解析</span>
                          <p className="text-base md:text-xl font-bold leading-relaxed">{currentQ.exp}</p>
                        </div>
                      )}

                      {lockTimer > 0 ? (
                        <p className={`text-base md:text-xl font-bold text-white ${feedback==='protected' ? 'bg-orange-900/40' : 'bg-red-900/40'} px-6 py-3 rounded-full mt-4 shrink-0 transition-all`}>
                          請閱讀解析，{lockTimer} 秒後可重新挑戰...
                        </p>
                      ) : (
                        <button 
                          onClick={handleRetryAfterWrong}
                          className={`mt-4 bg-white ${feedback==='protected' ? 'text-orange-600' : 'text-red-600'} px-8 py-3 rounded-full font-black text-xl shadow-lg hover:scale-105 active:scale-95 transition-all flex items-center gap-2 shrink-0`}
                        >
                          <RotateCcw size={24} /> 重新作答
                        </button>
                      )}
                    </div>
                  )}

                  {feedback === 'correct' && (
                    <div className="absolute inset-0 z-40 bg-green-500/90 flex flex-col items-center justify-center text-white animate-in fade-in duration-150">
                      <CheckCircle2 size={80} className="mb-4 animate-bounce" />
                      <h2 className="text-4xl font-black drop-shadow-md mb-2">答對了！</h2>
                      <p className="text-xl font-bold bg-green-800/40 px-6 py-2 rounded-full mt-2">
                        +{lastEarned} 餅乾 {doubleTimeLeft > 0 && '(雙倍!)'}
                      </p>
                    </div>
                  )}

                  <div className="p-4 md:p-8 flex items-center justify-center min-h-[120px] md:min-h-[160px] shrink-0 border-b border-slate-100">
                    <h2 className="text-lg sm:text-xl md:text-2xl font-black text-slate-800 leading-relaxed text-center break-words whitespace-pre-wrap w-full max-w-4xl">
                      {currentQ.q}
                    </h2>
                  </div>
                  
                  <div className="p-3 sm:p-4 md:p-6 bg-slate-50 mt-auto shrink-0 flex-1 flex flex-col justify-end">
                    <div className={`grid gap-2 sm:gap-3 md:gap-4 max-w-4xl mx-auto w-full ${needsSingleColumn ? 'grid-cols-1' : 'grid-cols-1 sm:grid-cols-2'}`}>
                      {options.map((opt, idx) => (
                        <button 
                          key={idx}
                          disabled={isProcessing && feedback !== 'retry_mode'}
                          onClick={() => {
                              if (feedback === 'retry_mode') handleRetry(opt);
                              else handleAnswer(opt);
                          }}
                          className="bg-white hover:bg-emerald-50 text-slate-700 hover:text-emerald-700 border-2 border-slate-200 hover:border-emerald-300 rounded-2xl p-3 md:p-5 transition-all active:scale-95 text-left flex items-start w-full shadow-sm group"
                        >
                          <span className="shrink-0 text-emerald-500 font-black text-lg md:text-xl w-7 md:w-8 mt-0.5 group-hover:text-emerald-600 transition-colors">
                            {idx + 1}.
                          </span>
                          <span className="flex-1 text-sm sm:text-base md:text-lg font-bold leading-relaxed break-words whitespace-normal text-slate-700">
                            {opt}
                          </span>
                        </button>
                      ))}
                    </div>
                  </div>
                </div>
              )}
            </div>
          );
        }

        function Dashboard({ correct, wrong, records, time }) {
          const formatTime = (s) => {
            const m = Math.floor(s / 60);
            const secs = s % 60;
            return `${m}分 ${secs}秒`;
          };

          return (
            <div className="h-full flex flex-col w-full max-w-4xl mx-auto overflow-hidden pb-4">
              <h2 className="text-2xl md:text-3xl font-black text-slate-800 mb-4 md:mb-6 shrink-0 flex items-center gap-2">
                <LibraryBig className="text-purple-500"/> 學習儀表板
              </h2>
              
              <div className="flex justify-between gap-2 md:gap-4 mb-4 md:mb-6 shrink-0 w-full px-1">
                <div className="flex-1 bg-blue-50 p-2 md:p-4 rounded-xl md:rounded-2xl border border-blue-100 text-center flex flex-col justify-center">
                  <div className="text-[10px] sm:text-xs md:text-sm font-bold text-blue-500 mb-1 whitespace-nowrap">修練時間</div>
                  <div className="text-sm sm:text-lg md:text-3xl font-black text-blue-700 whitespace-nowrap">{formatTime(time)}</div>
                </div>
                <div className="flex-1 bg-green-50 p-2 md:p-4 rounded-xl md:rounded-2xl border border-green-100 text-center flex flex-col justify-center">
                  <div className="text-[10px] sm:text-xs md:text-sm font-bold text-green-500 mb-1 whitespace-nowrap">精通題數</div>
                  <div className="text-base sm:text-xl md:text-3xl font-black text-green-700 whitespace-nowrap">{correct}</div>
                </div>
                <div className="flex-1 bg-red-50 p-2 md:p-4 rounded-xl md:rounded-2xl border border-red-100 text-center flex flex-col justify-center">
                  <div className="text-[10px] sm:text-xs md:text-sm font-bold text-red-500 mb-1 whitespace-nowrap">待加強</div>
                  <div className="text-base sm:text-xl md:text-3xl font-black text-red-700 whitespace-nowrap">{wrong}</div>
                </div>
              </div>

              <div className="flex-1 bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden flex flex-col min-h-0 mx-1 md:mx-0">
                <div className="bg-slate-50 px-4 md:px-6 py-3 md:py-4 border-b border-slate-200 font-black text-slate-700 shrink-0 text-sm md:text-base">
                  反覆錯題紀錄 (共 {records.length} 題)
                </div>
                <div className="flex-1 overflow-y-auto p-3 md:p-6 space-y-3 md:space-y-4">
                  {records.length === 0 ? (
                    <div className="text-center text-slate-400 mt-10 font-bold text-sm md:text-lg">太厲害了！目前沒有任何錯題紀錄！</div>
                  ) : (
                    records.map((r, i) => (
                      <div key={i} className="bg-red-50/50 p-3 md:p-4 rounded-xl border border-red-100">
