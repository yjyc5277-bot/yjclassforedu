        function TeacherDashboard({ dailyRecords }) {
          const formatTime = (s) => {
            const m = Math.floor(s / 60);
            const secs = s % 60;
            return `${m}分 ${secs}秒`;
          };

          // 排序：日期由新到舊，同日期依姓名排序
          const sortedRecords = [...dailyRecords].sort((a, b) => {
              const dDiff = new Date(b.date).getTime() - new Date(a.date).getTime();
              if (dDiff !== 0) return dDiff;
              return a.name.localeCompare(b.name);
          });

          const exportCSV = () => {
            const headers = ['日期', '學生姓名', '寵物家族', '寵物等級', '可用餅乾', '歷史累計餅乾', '本日答對', '本日答錯', '本日正確率', '本日學習時間'];
            const csvContent = [
              headers.join(','),
              ...sortedRecords.map(s => {
                const total = (s.correct || 0) + (s.wrong || 0);
                const rate = total === 0 ? '0%' : Math.round(((s.correct || 0) / total) * 100) + '%';
                return `${s.date || ''},${s.name},${s.petFamily || ''},${s.level || 1},${s.cookies || 0},${s.totalCookies || s.cookies || 0},${s.correct || 0},${s.wrong || 0},${rate},${formatTime(s.time || 0)}`;
              })
            ].join('\n');
            
            const blob = new Blob(["\uFEFF" + csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = '學堂每日學習追蹤資料.csv';
            link.click();
            URL.revokeObjectURL(url);
          };

          return (
            <div className="min-h-screen bg-slate-50 flex flex-col p-4 md:p-8 overflow-y-auto">
              <div className="max-w-6xl mx-auto w-full flex-1 flex flex-col">
                <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 md:mb-8 gap-4">
                  <div>
                    <button onClick={() => window.location.reload()} className="flex items-center gap-2 text-slate-500 hover:text-emerald-600 font-bold mb-2 transition-colors">
                      <ArrowLeft size={20} /> 返回登入畫面
                    </button>
                    <h1 className="text-2xl md:text-4xl font-black text-slate-800 flex items-center gap-2 md:gap-3">
                      <BarChart className="text-emerald-500" size={32} /> 教師每日追蹤後台
                    </h1>
                  </div>
                  <button 
                    onClick={exportCSV}
                    className="bg-emerald-500 text-white px-4 py-2 md:px-6 md:py-3 rounded-xl font-bold flex items-center gap-2 hover:bg-emerald-600 active:scale-95 shadow-md transition-all text-sm md:text-base"
                  >
                    <Download size={18} /> 匯出 CSV 資料
                  </button>
                </div>

                <div className="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden flex-1 flex flex-col">
                  <div className="overflow-x-auto">
                    <table className="w-full text-left border-collapse min-w-[1000px]">
                      <thead>
                        <tr className="bg-slate-100 text-slate-600 font-bold text-xs md:text-sm uppercase tracking-wider">
                          <th className="p-3 md:p-4 border-b border-slate-200">登入日期</th>
                          <th className="p-3 md:p-4 border-b border-slate-200">學生姓名</th>
                          <th className="p-3 md:p-4 border-b border-slate-200">選擇寵物</th>
                          <th className="p-3 md:p-4 border-b border-slate-200 text-center">寵物等級</th>
                          <th className="p-3 md:p-4 border-b border-slate-200 text-right">可用餅乾</th>
                          <th className="p-3 md:p-4 border-b border-slate-200 text-right">歷史累計餅乾</th>
                          <th className="p-3 md:p-4 border-b border-slate-200 text-right bg-blue-50">本日答對</th>
                          <th className="p-3 md:p-4 border-b border-slate-200 text-right bg-blue-50">本日答錯</th>
                          <th className="p-3 md:p-4 border-b border-slate-200 text-center bg-blue-50">本日正確率</th>
                          <th className="p-3 md:p-4 border-b border-slate-200 text-right bg-blue-50">本日學習時間</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-slate-100 text-sm md:text-base">
                        {sortedRecords.map((student, idx) => {
                          const total = (student.correct || 0) + (student.wrong || 0);
                          const accuracy = total === 0 ? 0 : Math.round(((student.correct || 0) / total) * 100);
                          
                          return (
                            <tr key={idx} className="hover:bg-emerald-50/50 transition-colors">
                              <td className="p-3 md:p-4 font-black text-slate-500">{student.date}</td>
                              <td className="p-3 md:p-4 font-black text-slate-800">{student.name}</td>
                              <td className="p-3 md:p-4 font-bold text-emerald-600">{student.petFamily}</td>
                              <td className="p-3 md:p-4 text-center">
                                <span className="bg-emerald-100 text-emerald-800 px-2 py-1 md:px-3 md:py-1 rounded-full font-bold">
                                  Lv.{student.level}
                                </span>
                              </td>
                              <td className="p-3 md:p-4 text-right font-bold text-orange-500">{student.cookies}</td>
                              <td className="p-3 md:p-4 text-right font-black text-orange-600">{student.totalCookies || student.cookies || 0}</td>
                              <td className="p-3 md:p-4 text-right font-bold text-green-600 bg-blue-50/30">{student.correct}</td>
                              <td className="p-3 md:p-4 text-right font-bold text-red-500 bg-blue-50/30">{student.wrong}</td>
                              <td className="p-3 md:p-4 text-center bg-blue-50/30">
                                <div className="flex items-center justify-center gap-2">
                                  <div className="w-12 md:w-16 h-2 bg-slate-200 rounded-full overflow-hidden">
                                    <div className="h-full bg-blue-500" style={{ width: `${accuracy}%` }}></div>
                                  </div>
                                  <span className="font-bold text-slate-600 w-8">{accuracy}%</span>
                                </div>
                              </td>
                              <td className="p-3 md:p-4 text-right font-bold text-slate-600 bg-blue-50/30">{formatTime(student.time)}</td>
                            </tr>
                          );
                        })}
                        {sortedRecords.length === 0 && (
                          <tr>
                            <td colSpan="10" className="p-8 text-center text-slate-400 font-bold">
                              目前尚無學生紀錄
                            </td>
                          </tr>
                        )}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          );
        }

        // --- 主應用程式 ---
        function App() {
          const [appMode, setAppMode] = useState('login'); 
          const [hasJoined, setHasJoined] = useState(false);
          const [nickname, setNickname] = useState('');
          const [petFamilyId, setPetFamilyId] = useState('');
          
          const [tab, setTab] = useState('rank'); // 預設改為風雲榜
          const [cookies, setCookies] = useState(0);
          const [totalCookies, setTotalCookies] = useState(0); // 歷史總累計
          const [petsData, setPetsData] = useState({}); 
          
          const [correctCount, setCorrectCount] = useState(0); // 本日答對
          const [wrongCount, setWrongCount] = useState(0);     // 本日答錯
          const [wrongRecords, setWrongRecords] = useState([]);
          const [timeSpent, setTimeSpent] = useState(0);       // 本日時間
          
          const [inventory, setInventory] = useState([]);
          const [activeEquipment, setActiveEquipment] = useState(null); // 當前裝備ID
          const [protectionCooldown, setProtectionCooldown] = useState(0); // 免死金牌冷卻
          const [woodOxTimer, setWoodOxTimer] = useState(0); // 木牛流馬計時
          const [consecutiveWrongs, setConsecutiveWrongs] = useState(0); // 連續答錯計數
          const [forcedCooldown, setForcedCooldown] = useState(0); // 強制冷靜倒數
          
          const [gachaResult, setGachaResult] = useState(null);
          const [alertMsg, setAlertMsg] = useState('');
          const [showTutorial, setShowTutorial] = useState(false);
          const [showLogoutConfirm, setShowLogoutConfirm] = useState(false);
          
          const [streak, setStreak] = useState(0);
          const [showChests, setShowChests] = useState(false);
          const [doubleTimeLeft, setDoubleTimeLeft] = useState(0);
          const [monsterEvent, setMonsterEvent] = useState(null);
          
          // 每日任務狀態
          const todayStr = new Date().toLocaleDateString('zh-TW');
          const [quests, setQuests] = useState({ date: todayStr, correct: 0, c_correct: false, streak10: 0, c_streak10: false, feed: 0, c_feed: false, gacha: 0, c_gacha: false });
          const [showQuests, setShowQuests] = useState(false);
          
          const [studentsList, setStudentsList] = useState([]); // 風雲榜(歷史累計)
          const [dailyRecordsList, setDailyRecordsList] = useState([]); // 教師後台(按日)

          // Firebase 初始化監聽全班資料 (分兩軌)
          useEffect(() => {
            if (isFirebaseActive) {
                // 1. 歷史總檔 (給風雲榜與登入回復)
                const unsub1 = db.collection('chinese_game_students').onSnapshot(snap => {
                    const list = [];
                    snap.forEach(doc => list.push({ id: doc.id, ...doc.data() }));
                    setStudentsList(list);
                    try { localStorage.setItem('pet_game_students', JSON.stringify(list)); } catch(e){}
                });
                // 2. 每日紀錄檔 (給教師後台)
                const unsub2 = db.collection('chinese_game_daily_records').onSnapshot(snap => {
                    const list = [];
                    snap.forEach(doc => list.push({ id: doc.id, ...doc.data() }));
                    setDailyRecordsList(list);
                    try { localStorage.setItem('pet_game_daily', JSON.stringify(list)); } catch(e){}
                });
                return () => { unsub1(); unsub2(); };
            } else {
                try {
                    const saved1 = localStorage.getItem('pet_game_students');
                    if (saved1) setStudentsList(JSON.parse(saved1));
                    const saved2 = localStorage.getItem('pet_game_daily');
                    if (saved2) setDailyRecordsList(JSON.parse(saved2));
                } catch(e){}
            }
          }, []);

          // 核心存檔邏輯
          const syncPlayerData = () => {
              if (!hasJoined || !nickname) return;
              
              const d = new Date();
              const today = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
              const docIdDaily = `${nickname}_${today}`;
              
              const currentLevel = petsData[petFamilyId]?.level || 1;
              const petName = PET_FAMILIES.find(f => f.id === petFamilyId)?.name || '';

              // 給風雲榜的總檔 (保留所有裝備進度與任務)
              const profileData = {
                  name: nickname,
                  date: today,
                  petFamily: petName,
                  level: currentLevel,
                  cookies,
                  totalCookies,
                  petsData,
                  inventory,
                  activeEquipment,
                  quests
              };

              // 給教師後台的每日檔 (只包含當日分數與現有錢包狀態)
              const dailyData = {
                  name: nickname,
                  date: today,
                  petFamily: petName,
                  level: currentLevel,
                  cookies,
                  totalCookies,
                  correct: correctCount,
                  wrong: wrongCount,
                  time: timeSpent
              };

              if (isFirebaseActive) {
                  db.collection('chinese_game_students').doc(nickname).set(profileData, { merge: true });
                  db.collection('chinese_game_daily_records').doc(docIdDaily).set(dailyData, { merge: true });
              } else {
                  // 本機模式的處理
                  setStudentsList(prev => {
                      const newList = [...prev];
                      const idx = newList.findIndex(s => s.name === nickname);
                      if (idx >= 0) newList[idx] = { ...newList[idx], ...profileData };
                      else newList.push({ id: Date.now(), ...profileData });
                      try { localStorage.setItem('pet_game_students', JSON.stringify(newList)); } catch(e){}
                      return newList;
                  });
                  setDailyRecordsList(prev => {
                      const newList = [...prev];
                      const idx = newList.findIndex(d => d.name === nickname && d.date === today);
                      if (idx >= 0) newList[idx] = { ...newList[idx], ...dailyData };
                      else newList.push({ id: Date.now(), ...dailyData });
                      try { localStorage.setItem('pet_game_daily', JSON.stringify(newList)); } catch(e){}
                      return newList;
                  });
              }
          };

          // 監聽重要狀態改變時自動存檔
          useEffect(() => {
              if (hasJoined) syncPlayerData();
          }, [cookies, totalCookies, petsData, correctCount, wrongCount, inventory, activeEquipment, quests]);

          // 每秒計時，處理各類冷卻與掛機裝備
          useEffect(() => {
            let timer;
            if (appMode === 'student') {
              timer = setInterval(() => {
                setTimeSpent(prev => {
                    const next = prev + 1;
                    if (next % 10 === 0) setTimeout(() => syncPlayerData(), 0);
                    return next;
                });
                
                setDoubleTimeLeft(prev => prev > 0 ? prev - 1 : 0);
                setProtectionCooldown(prev => prev > 0 ? prev - 1 : 0);
                setForcedCooldown(prev => prev > 0 ? prev - 1 : 0);
                
                // 裝備 13: 諸葛亮的木牛流馬 (每 5 分鐘自動 +10 餅乾)
                if (activeEquipment === 13) {
                    setWoodOxTimer(prev => {
                        if (prev + 1 >= 300) {
                            setCookies(c => c + 10);
                            setTotalCookies(c => c + 10);
                            playSound('correct');
                            return 0;
                        }
                        return prev + 1;
                    });
                } else {
                    setWoodOxTimer(0);
                }
                
                // 妖怪倒數
                setMonsterEvent(prev => {
                    if (prev) {
                        if (prev.timeLeft > 1) return { ...prev, timeLeft: prev.timeLeft - 1 };
                        else {
                            handleMonsterTimeout();
                            return null;
                        }
                    }
                    return prev;
                });

              }, 1000);
            }
            return () => clearInterval(timer);
          }, [appMode, hasJoined, nickname, activeEquipment]); // 加入 activeEquipment 作為 dependency

          const handleMonsterTimeout = () => {
              playSound('wrong');
              // 裝備 15: 司馬光的破水缸
              if (activeEquipment === 15 && Math.random() < 0.5) {
                  setAlertMsg('💧 司馬光的破水缸發揮作用！擋下了妖怪的攻擊，沒有損失餅乾！');
              } else {
                  setCookies(prev => Math.max(0, prev - 5));
                  setAlertMsg('💥 時間到！錯別字妖怪搶走了 5 個餅乾！');
              }
          };

          const handleLogin = (name, familyId) => {
            setNickname(name);
            const d = new Date();
            const today = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
            
            // 讀取歷史累積總檔
            const existingProfile = studentsList.find(s => s.name === name);
            if (existingProfile) {
                setCookies(existingProfile.cookies || 0);
                setTotalCookies(existingProfile.totalCookies || existingProfile.cookies || 0);
                setInventory(existingProfile.inventory || []);
                setActiveEquipment(existingProfile.activeEquipment || null);
                
                if (existingProfile.quests && existingProfile.quests.date === today) {
                    setQuests(existingProfile.quests);
                } else {
                    setQuests({ date: today, correct: 0, c_correct: false, streak10: 0, c_streak10: false, feed: 0, c_feed: false, gacha: 0, c_gacha: false });
                }

                if (existingProfile.petsData) {
                    setPetsData(existingProfile.petsData);
                    if (!existingProfile.petsData[familyId]) {
                        setPetsData(prev => ({...prev, [familyId]: {level: 1, exp: 0}}));
                    }
                } else {
                    setPetsData({ [familyId]: { level: existingProfile.level || 1, exp: 0 } });
                }
            } else {
                setCookies(0);
                setTotalCookies(0);
                setInventory([]);
                setActiveEquipment(null);
                setPetsData({ [familyId]: { level: 1, exp: 0 } });
                setQuests({ date: today, correct: 0, c_correct: false, streak10: 0, c_streak10: false, feed: 0, c_feed: false, gacha: 0, c_gacha: false });
            }

            // 讀取今日紀錄檔 (為了重置今日的答題數與時間)
            const existingDaily = dailyRecordsList.find(d => d.name === name && d.date === today);
            if (existingDaily) {
                setCorrectCount(existingDaily.correct || 0);
                setWrongCount(existingDaily.wrong || 0);
                setTimeSpent(existingDaily.time || 0);
            } else {
                setCorrectCount(0);
                setWrongCount(0);
                setTimeSpent(0);
            }

            setPetFamilyId(familyId);
            setHasJoined(true);
            setAppMode('student');
            setShowTutorial(true);
            setTimeout(() => syncPlayerData(), 100); 
          };

          const handleLogout = () => {
            syncPlayerData(); 
            setShowLogoutConfirm(false);
            setAppMode('login');
            setHasJoined(false);
            setNickname('');
            setPetFamilyId('');
            setCookies(0);
            setTotalCookies(0);
            setPetsData({});
            setCorrectCount(0);
            setWrongCount(0);
            setWrongRecords([]);
            setTimeSpent(0);
            setInventory([]);
            setActiveEquipment(null);
            setStreak(0);
            setDoubleTimeLeft(0);
            setMonsterEvent(null);
            setConsecutiveWrongs(0);
            setForcedCooldown(0);
            setTab('rank'); // 登出後也維持預設分頁為榜單
          };

          const triggerMonster = (currentBook) => {
              const bookConf = BOOKS.find(b => b.id === currentBook);
              let stage1Pool = [];
              if (bookConf?.type === 'exam') {
                  bookConf.pools.forEach(bId => {
                      if (QUESTION_BANK[bId] && QUESTION_BANK[bId].stage1) {
                          stage1Pool = stage1Pool.concat(QUESTION_BANK[bId].stage1);
                      }
                  });
              } else {
                  stage1Pool = QUESTION_BANK[currentBook]?.stage1 || [];
              }
              
              if (stage1Pool.length === 0) return;
              
              // 裝備 12: 包青天的狗頭鍘
              if (activeEquipment === 12 && Math.random() < 0.5) {
                  playSound('correct');
                  setCookies(prev => prev + 15);
                  setTotalCookies(prev => prev + 15);
                  setAlertMsg('🪓 包青天的狗頭鍘發威！瞬間秒殺路過的錯別字妖怪，直接獲得 15 餅乾！');
                  return;
              }

              const q = stage1Pool[Math.floor(Math.random() * stage1Pool.length)];
              setMonsterEvent({
                  question: q,
                  options: shuffleArray([...q.options]),
                  timeLeft: 10 // 限時 10 秒
              });
          };

          const handleQuizResult = (isCorrect, qData, userAns, baseReward, targetStreak, isRetry, usedProtection, currentBook, selectedStage) => {
            if (isCorrect) {
              setConsecutiveWrongs(0); // 答對重置連續錯誤計數

              // 重答獎勵減半 (向上取整)
              let currentBaseReward = isRetry ? Math.ceil(baseReward / 2) : baseReward;

              // 裝備 6: 孔明羽扇
              let eqBonus = activeEquipment === 6 ? 1 : 0;
              
              // 裝備 14: 和氏璧 (關卡三 +3)
              if (activeEquipment === 14 && selectedStage === 'stage3') eqBonus += 3;
              
              // 裝備 10: 王羲之的墨寶 (重答成功 +2)
              if (isRetry && activeEquipment === 10) eqBonus += 2;

              let finalReward = doubleTimeLeft > 0 ? (currentBaseReward + eqBonus) * 2 : (currentBaseReward + eqBonus);

              // 裝備 5: 李白的酒壺
              if (activeEquipment === 5 && Math.random() < 0.1) {
                  finalReward *= 3;
                  setTimeout(() => setAlertMsg('🍶 李白的酒壺引發靈感！這題獲得 3 倍餅乾！'), 500);
              }

              setCorrectCount(prev => prev + 1);
              setCookies(prev => prev + finalReward);
              setTotalCookies(prev => prev + finalReward);
              
              // 每日任務：勤學苦練
              setQuests(prev => ({...prev, correct: prev.correct + 1}));

              if (!isRetry) {
                  // 妖怪機率 10%
                  if (!monsterEvent && doubleTimeLeft === 0 && Math.random() < 0.10) {
                      triggerMonster(currentBook);
                  } 
                  // 財神爺機率 8% (若裝備指南針則為 15%)
                  else if (!monsterEvent && doubleTimeLeft === 0 && Math.random() < (activeEquipment === 18 ? 0.15 : 0.08)) {
                      // 裝備 19: 傳說夜明珠 (時間延長至 90 秒)
                      setDoubleTimeLeft(activeEquipment === 19 ? 90 : 60); 
                      setAlertMsg('✨ 財神爺降臨！未來時間內，答對題目的餅乾獎勵全部雙倍！ ✨');
                  }

                  setStreak(prev => {
                    const nextStreak = prev + 1;
                    if (nextStreak === targetStreak) {
                      setQuests(q => ({...q, streak10: 1})); // 每日任務：觸發一次連擊寶箱
                      setTimeout(() => setShowChests(true), 800);
                      return 0; 
                    }
                    return nextStreak;
                  });
              }
            } else {
              // 答錯邏輯：只有第一次答錯才計入連續錯誤
              if (!isRetry) {
                  setConsecutiveWrongs(prev => {
                      const next = prev + 1;
                      if (next >= 4) {
                          setForcedCooldown(5); // 觸發強制冷靜 5 秒
                          return 0; // 重置計數
                      }
                      return next;
                  });
              }

              if (!isRetry && !usedProtection) {
                  setStreak(0); 
              }
              if (!isRetry) {
                  setWrongCount(prev => prev + 1);
                  setWrongRecords(prev => {
                    if (prev.find(item => item.q === qData.q)) return prev;
                    return [...prev, { q: qData.q, a: qData.a, userAns }];
                  });
              }
            }
          };

          const handleMonsterResult = (isCorrect) => {
              if (isCorrect) {
                  playSound('correct');
                  // 裝備 9: 青龍偃月刀
                  const reward = activeEquipment === 9 ? 30 : 15;
                  setCookies(prev => prev + reward);
                  setTotalCookies(prev => prev + reward);
                  setAlertMsg(`⚔️ 成功擊退妖怪！獲得寶箱 ${reward} 個餅乾！`);
              } else {
                  playSound('wrong');
                  // 裝備 15: 司馬光的破水缸
                  if (activeEquipment === 15 && Math.random() < 0.5) {
                      setAlertMsg('💧 司馬光的破水缸發揮作用！擋下了妖怪的攻擊，沒有損失餅乾！');
                  } else {
                      setCookies(prev => Math.max(0, prev - 5));
                      setAlertMsg('💥 答錯了！錯別字妖怪搶走了 5 個餅乾！');
                  }
              }
              setMonsterEvent(null);
          };

          const feedPet = () => {
            const pet = petsData[petFamilyId];
            if (!pet) return;
            // 裝備 2: 玉如意
            const cost = activeEquipment === 2 ? 8 : 10;
            
            if (cookies >= cost && pet.level < 5) {
              setCookies(prev => prev - cost);
              
              // 每日任務：守護者的愛
              setQuests(prev => ({...prev, feed: prev.feed + 1}));

              // 裝備 11: 蘇東坡的東坡肉
              let expGain = activeEquipment === 11 ? 15 : 10;
              // 裝備 1: 狀元帽爆擊
              if (activeEquipment === 1 && Math.random() < 0.2) {
                  expGain = 20;
                  playSound('correct');
              }

              setPetsData(prev => {
                const newData = { ...prev };
                const p = { ...newData[petFamilyId] };
                p.exp += expGain;
                if (p.exp >= p.level * 80) { 
                  p.level = Math.min(p.level + 1, 5);
                  p.exp = 0; 
                  // 滿等畢業獎勵 (+100 餅乾)
                  if (p.level === 5 && prev[petFamilyId].level < 5) {
                      setTimeout(() => {
                          playSound('correct');
                          setCookies(c => c + 100);
                          setTotalCookies(c => c + 100);
                          setAlertMsg('🎉 恭喜！守護靈已達最高型態，獲得 100 餅乾畢業獎金！');
                      }, 500);
                  }
                }
                newData[petFamilyId] = p;
                return newData;
              });
            }
          };

          const drawGacha = () => {
            if (cookies >= 50) {
              setCookies(prev => prev - 50);
              
              // 每日任務：試氣手運
              setQuests(prev => ({...prev, gacha: prev.gacha + 1}));

              const randomItem = GACHA_ITEMS[Math.floor(Math.random() * GACHA_ITEMS.length)];
              setInventory(prev => {
                if (!prev.includes(randomItem.id)) {
                  return [...prev, randomItem.id];
                }
                return prev;
              });
              setGachaResult(randomItem);
            } else {
              setAlertMsg('餅乾不足 50 個喔！快去「試煉」答題賺取吧！');
            }
          };

          const handleEquip = (itemId) => {
              setActiveEquipment(itemId);
          };

          const claimQuest = (type, reward) => {
              setQuests(prev => ({...prev, [`c_${type}`]: true}));
              setCookies(prev => prev + reward);
              setTotalCookies(prev => prev + reward);
              playSound('correct');
              setAlertMsg(`🎁 任務完成！獲得 ${reward} 餅乾！`);
          };

          if (appMode === 'login') return <LoginScreen onJoin={handleLogin} onTeacherClick={() => setAppMode('teacher')} />;
          if (appMode === 'teacher') return <TeacherDashboard dailyRecords={dailyRecordsList} onBack={() => setAppMode('login')} />;

          const eqItem = GACHA_ITEMS.find(i => i.id === activeEquipment);
          const unclaimedQuest = (quests.correct >= 30 && !quests.c_correct) || (quests.streak10 >= 1 && !quests.c_streak10) || (quests.feed >= 3 && !quests.c_feed) || (quests.gacha >= 1 && !quests.c_gacha);

          return (
            <div className="flex flex-col h-screen w-full bg-emerald-50 text-slate-800 font-sans">
              <div className="flex md:hidden justify-between items-center p-3 bg-white shadow-sm border-b border-emerald-100 z-20 shrink-0">
                <div className="font-bold text-emerald-700 flex items-center gap-1"><User size={16}/> {nickname}</div>
                <div className="flex gap-2">
                    <button onClick={()=>setShowQuests(true)} className="bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-xs font-bold flex items-center shadow-sm relative">
                       <ClipboardList size={16}/> 任務
                       {unclaimedQuest ? <span className="absolute -top-1 -right-1 w-2 h-2 bg-red-500 rounded-full animate-ping"></span> : null}
                    </button>
                    <div className="bg-orange-100 text-orange-800 px-3 py-1 rounded-full text-sm font-bold flex items-center gap-1">
                      <Cookie size={16} className="text-orange-500 fill-orange-500"/> {cookies}
                    </div>
                </div>
              </div>

              {/* 每日任務懸浮按鈕 (電腦版) */}
              <div className="hidden md:block">
                  {appMode === 'student' && hasJoined && (
                      <button 
                        onClick={() => setShowQuests(true)}
                        className="absolute top-4 right-4 bg-yellow-100 text-yellow-800 px-4 py-2 rounded-xl font-bold flex items-center gap-2 shadow-sm border border-yellow-300 transition-all hover:scale-105 active:scale-95 z-40"
                      >
                        <ClipboardList size={20} /> 每日任務
                        {unclaimedQuest ? <span className="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full animate-ping"></span> : null}
                      </button>
                  )}
              </div>

              {/* 每日任務面板 */}
              {showQuests && (
                 <div className="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" onClick={() => setShowQuests(false)}>
                   <div className="bg-white rounded-3xl p-6 md:p-8 max-w-md w-full shadow-2xl relative" onClick={e=>e.stopPropagation()}>
                     <h2 className="text-2xl font-black text-amber-600 mb-4 flex items-center gap-2"><ClipboardList /> 每日任務</h2>
                     
                     <div className="space-y-4">
                       <div className="bg-slate-50 p-4 rounded-2xl border border-slate-200 flex justify-between items-center">
                          <div>
                              <div className="font-bold text-slate-800">勤學苦練</div>
                              <div className="text-xs text-slate-500">本日累計答對 30 題 ({quests.correct}/30)</div>
                          </div>
                          {quests.c_correct ? <span className="text-green-500 font-black text-sm">✅ 已領取</span> : 
                              <button onClick={() => claimQuest('correct', 30)} disabled={quests.correct < 30} className={`px-4 py-2 rounded-xl font-bold text-sm shadow-sm transition-all active:scale-95 ${quests.correct >= 30 ? 'bg-amber-400 text-white animate-pulse' : 'bg-slate-200 text-slate-400'}`}>領取 30 🍪</button>
                          }
                       </div>
                       <div className="bg-slate-50 p-4 rounded-2xl border border-slate-200 flex justify-between items-center">
                          <div>
                              <div className="font-bold text-slate-800">百發百中</div>
                              <div className="text-xs text-slate-500">觸發 1 次連擊寶箱 ({quests.streak10}/1)</div>
                          </div>
                          {quests.c_streak10 ? <span className="text-green-500 font-black text-sm">✅ 已領取</span> : 
                              <button onClick={() => claimQuest('streak10', 20)} disabled={quests.streak10 < 1} className={`px-4 py-2 rounded-xl font-bold text-sm shadow-sm transition-all active:scale-95 ${quests.streak10 >= 1 ? 'bg-amber-400 text-white animate-pulse' : 'bg-slate-200 text-slate-400'}`}>領取 20 🍪</button>
                          }
                       </div>
                       <div className="bg-slate-50 p-4 rounded-2xl border border-slate-200 flex justify-between items-center">
                          <div>
                              <div className="font-bold text-slate-800">守護者的愛</div>
                              <div className="text-xs text-slate-500">餵食守護靈 3 次 ({quests.feed}/3)</div>
                          </div>
                          {quests.c_feed ? <span className="text-green-500 font-black text-sm">✅ 已領取</span> : 
                              <button onClick={() => claimQuest('feed', 15)} disabled={quests.feed < 3} className={`px-4 py-2 rounded-xl font-bold text-sm shadow-sm transition-all active:scale-95 ${quests.feed >= 3 ? 'bg-amber-400 text-white animate-pulse' : 'bg-slate-200 text-slate-400'}`}>領取 15 🍪</button>
                          }
                       </div>
                       <div className="bg-slate-50 p-4 rounded-2xl border border-slate-200 flex justify-between items-center">
                          <div>
                              <div className="font-bold text-slate-800">試氣手運</div>
                              <div className="text-xs text-slate-500">抽取 1 次盲盒 ({quests.gacha}/1)</div>
                          </div>
                          {quests.c_gacha ? <span className="text-green-500 font-black text-sm">✅ 已領取</span> : 
                              <button onClick={() => claimQuest('gacha', 20)} disabled={quests.gacha < 1} className={`px-4 py-2 rounded-xl font-bold text-sm shadow-sm transition-all active:scale-95 ${quests.gacha >= 1 ? 'bg-amber-400 text-white animate-pulse' : 'bg-slate-200 text-slate-400'}`}>領取 20 🍪</button>
                          }
                       </div>
                     </div>

                     <button onClick={() => setShowQuests(false)} className="mt-6 w-full bg-slate-200 text-slate-700 py-3 rounded-2xl font-black shadow-sm hover:bg-slate-300 transition-all active:scale-95">關閉</button>
                   </div>
                 </div>
              )}

              <div className="flex flex-col md:flex-row flex-1 min-h-0 overflow-hidden max-w-7xl mx-auto w-full md:p-4 gap-4">
                
                {/* 左側選單 */}
                <nav className="
                  order-2 md:order-1
                  fixed bottom-0 left-0 w-full bg-white border-t border-emerald-100 z-30 pb-safe
                  md:relative md:w-40 lg:w-48 md:rounded-3xl md:border-none md:shadow-xl md:flex md:flex-col md:p-4
                  flex justify-around items-center md:items-stretch
                  h-16 md:h-auto shrink-0
                ">
                  <div className="hidden md:block text-center mb-6 shrink-0">
                    <h1 className="text-xl lg:text-2xl font-black text-emerald-700">國文養成學堂</h1>
                    <p className="text-slate-500 text-xs lg:text-sm mt-1 font-bold">{nickname} 的專屬寵物</p>
                  </div>

                  <div className="hidden md:flex bg-orange-50 p-3 lg:p-4 rounded-2xl mb-6 border border-orange-100 items-center justify-between shadow-sm shrink-0">
                    <span className="font-bold text-orange-800 text-sm lg:text-base">餅乾罐</span>
                    <span className="font-black text-xl lg:text-2xl text-orange-600 flex items-center gap-1">
                      <Cookie className="fill-orange-500 text-orange-500" /> {cookies}
                    </span>
                  </div>

                  <div className="flex md:flex-col w-full p-1 md:p-0 justify-around md:justify-start h-full items-center md:items-stretch gap-1 md:gap-2">
                    <NavBtn active={tab==='rank'} onClick={()=>setTab('rank')} icon={Trophy} label="風雲榜" />
                    <NavBtn active={tab==='quiz'} onClick={()=>setTab('quiz')} icon={BookOpen} label="試煉" />
                    <NavBtn active={tab==='pet'} onClick={()=>setTab('pet')} icon={Home} label="守護靈" />
                    <NavBtn active={tab==='gacha'} onClick={()=>setTab('gacha')} icon={Gift} label="藏寶閣" />
                    <NavBtn active={tab==='dash'} onClick={()=>setTab('dash')} icon={LibraryBig} label="錯題" />
                    <div className="hidden md:block mt-auto pt-4 border-t border-slate-100 w-full">
                       <NavBtn active={false} onClick={() => setShowLogoutConfirm(true)} icon={LogOut} label="登出存檔" />
                    </div>
                  </div>
                </nav>

                <main className="order-1 md:order-2 flex-1 bg-white/80 md:rounded-3xl md:shadow-xl border-0 md:border-8 border-white relative min-h-0 flex flex-col p-2 md:p-4 w-full">
                  <div className={`flex-1 min-h-0 flex-col ${tab === 'pet' ? 'flex' : 'hidden'}`}>
                    <PetRoom studentData={{petsData, activeFamilyId: petFamilyId, cookies}} onSwitch={setPetFamilyId} onUnlock={(id) => setPetsData(prev => ({...prev, [id]: {level: 1, exp: 0}}))} onFeed={feedPet} activeEquipment={eqItem} />
                  </div>
                  <div className={`flex-1 min-h-0 flex-col ${tab === 'quiz' ? 'flex' : 'hidden'}`}>
                    <QuizRoom onResult={handleQuizResult} currentCookies={cookies} streak={streak} onResetStreak={() => setStreak(0)} doubleTimeLeft={doubleTimeLeft} activeEquipment={eqItem} protectionCooldown={protectionCooldown} triggerProtection={() => setProtectionCooldown(180)} />
                  </div>
                  <div className={`flex-1 min-h-0 flex-col ${tab === 'dash' ? 'flex' : 'hidden'}`}>
                    <Dashboard correct={correctCount} wrong={wrongCount} records={wrongRecords} time={timeSpent} />
                  </div>
                  <div className={`flex-1 min-h-0 flex-col ${tab === 'rank' ? 'flex' : 'hidden'}`}>
                    <Leaderboard studentsList={studentsList} />
                  </div>
                  <div className={`flex-1 min-h-0 flex-col ${tab === 'gacha' ? 'flex' : 'hidden'}`}>
                    <GachaRoom cookies={cookies} onDraw={drawGacha} inventory={inventory} activeEquipmentId={activeEquipment} onEquip={handleEquip} />
                  </div>
                </main>
              </div>

              {/* 強制冷靜彈窗 (連錯 4 題觸發) */}
              {forcedCooldown > 0 && (
                <div className="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-red-900/95 backdrop-blur-md animate-in fade-in">
                  <div className="bg-slate-900 rounded-3xl p-8 max-w-md w-full shadow-2xl relative text-center border-4 border-red-500 animate-shake">
                    <AlertCircle size={60} className="mx-auto text-red-500 mb-4 animate-pulse" />
                    <h2 className="text-2xl md:text-3xl font-black text-white mb-4">⚠️ 系統偵測到連續答錯</h2>
                    <p className="text-red-200 font-bold mb-6 text-base md:text-lg leading-relaxed">
                      請深呼吸，仔細觀看題目與解析，回想重點後再選答案！
                    </p>
                    <div className="bg-red-950 text-red-400 py-3 rounded-xl font-black text-xl">
                      暫停 {forcedCooldown} 秒後繼續...
                    </div>
                  </div>
                </div>
              )}

              {/* 妖怪突襲彈窗 */}
              {monsterEvent && <MonsterModal monsterEvent={monsterEvent} onResult={handleMonsterResult} />}

              {/* 登出確認彈窗 */}
              {showLogoutConfirm && (
                <div className="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm animate-in fade-in" onClick={() => setShowLogoutConfirm(false)}>
                  <div className="bg-white rounded-3xl p-8 max-w-sm w-full shadow-2xl relative text-center" onClick={e=>e.stopPropagation()}>
                    <LogOut size={50} className="mx-auto text-emerald-500 mb-4" />
                    <h2 className="text-2xl font-black text-slate-800 mb-2">確定要登出嗎？</h2>
                    <p className="text-slate-500 font-bold mb-6">您的學習進度已經安全地儲存在系統中了！</p>
                    <div className="flex gap-3">
                      <button onClick={() => setShowLogoutConfirm(false)} className="flex-1 py-3 rounded-xl font-bold text-slate-500 bg-slate-100 hover:bg-slate-200 transition-all">取消</button>
                      <button onClick={handleLogout} className="flex-1 py-3 rounded-xl font-bold text-white bg-emerald-500 hover:bg-emerald-600 shadow-md transition-all">確定登出</button>
                    </div>
                  </div>
                </div>
              )}

              {/* 寶箱彈窗 */}
              {showChests && (
                <ChestModal 
                  onClose={() => setShowChests(false)} 
                  onReward={(amount) => {
                    if(amount > 0) {
                        // 裝備 7: 關羽的赤兔馬 (寶箱 +15)
                        const finalAmt = (activeEquipment === 7) ? amount + 15 : amount;
                        setCookies(prev => prev + finalAmt);
                        setTotalCookies(prev => prev + finalAmt);
                        if(activeEquipment === 7) setTimeout(() => setAlertMsg('🐎 赤兔馬發威！連擊寶箱額外獲得 15 餅乾！'), 300);
                    }
                  }} 
                />
              )}

              {/* 抽獎結果 */}
              {gachaResult && (
                <div className="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-black/70 backdrop-blur-sm animate-in fade-in" onClick={() => setGachaResult(null)}>
                  <div className="bg-white rounded-[2rem] p-8 max-w-sm w-full text-center shadow-2xl transform animate-in zoom-in-50 duration-300" onClick={e=>e.stopPropagation()}>
                    <div className="text-8xl mb-6 animate-bounce">{gachaResult.icon}</div>
                    <h2 className="text-3xl font-black text-pink-600 mb-2">獲得新藏品！</h2>
                    <p className="text-2xl font-bold text-slate-700 mb-2">{gachaResult.name}</p>
                    <p className="text-sm font-bold text-purple-600 mb-8 bg-purple-50 border border-purple-200 px-4 py-2 rounded-xl">裝備能力：{gachaResult.buff}</p>
                    <button onClick={() => setGachaResult(null)} className="w-full bg-pink-500 text-white py-4 rounded-2xl font-black text-xl shadow-lg hover:bg-pink-600 active:scale-95 transition-all">
                      開心收下
                    </button>
                  </div>
                </div>
              )}

              {/* 一般訊息 */}
              {alertMsg && (
                <div className="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm animate-in fade-in" onClick={() => setAlertMsg('')}>
                  <div className="bg-white rounded-[2rem] p-8 max-w-sm w-full text-center shadow-2xl transform animate-in zoom-in-90 duration-200" onClick={e=>e.stopPropagation()}>
                    {alertMsg.includes('財神') ? <Sparkles size={70} className="mx-auto mb-4 text-yellow-500 animate-pulse" /> : <AlertCircle size={70} className="mx-auto mb-4 text-orange-500" />}
                    <h2 className="text-2xl font-black text-slate-800 mb-6 leading-relaxed">{alertMsg}</h2>
                    <button onClick={() => setAlertMsg('')} className="w-full bg-slate-200 text-slate-700 py-4 rounded-2xl font-black text-xl shadow-sm hover:bg-slate-300 active:scale-95 transition-all">
                      我知道了
                    </button>
                  </div>
                </div>
              )}

              {showTutorial && (
                <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" onClick={() => setShowTutorial(false)}>
                  <div className="bg-white rounded-3xl p-6 md:p-8 max-w-md w-full shadow-2xl relative" onClick={e=>e.stopPropagation()}>
                    <h2 className="text-2xl font-black text-emerald-600 mb-4 flex items-center gap-2"><Info /> 學堂指南</h2>
                    <ul className="space-y-4 text-slate-600 font-bold text-lg">
                      <li className="flex items-start gap-2"><BookOpen className="text-blue-500 shrink-0 mt-1"/> 每次題目與選項都會<span className="font-black text-blue-500">重新洗牌</span>。</li>
                      <li className="flex items-start gap-2"><AlertCircle className="text-red-500 shrink-0 mt-1"/> 答錯會有 <span className="font-black text-red-500">語音解析並鎖定5秒</span>，解除鎖定後必須重新作答。</li>
                      <li className="flex items-start gap-2"><Flame className="text-amber-500 shrink-0 mt-1"/> 連續答對指定題數會觸發神祕寶箱！答題中可能觸發<span className="font-black text-yellow-500">財神爺雙倍</span>或<span className="font-black text-purple-500">妖怪突襲</span>！</li>
                      <li className="flex items-start gap-2"><Gift className="text-pink-500 shrink-0 mt-1"/> 抽到的藏品可以「裝備」在身上獲得強大效果。</li>
                    </ul>
                    <button onClick={() => setShowTutorial(false)} className="mt-8 w-full bg-emerald-500 text-white py-3 rounded-2xl font-black text-xl shadow-lg hover:bg-emerald-600 active:scale-95 transition-all">
                      我明白了，開始練功！
                    </button>
                  </div>
                </div>
              )}
            </div>
          );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
